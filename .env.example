# Fichier .env RACINE — utilisé uniquement sur le VPS (staging/prod), lu par
# docker-compose.staging.yml via la substitution ${VAR} native de Docker
# Compose. Différent de api/.env (celui-là est lu par le conteneur `web`
# via env_file, et n'existe pas sur un checkout local classique).
#
# Copier en `.env` (à la racine, à côté de docker-compose.yml) sur le VPS,
# ne jamais commiter le résultat.

# openssl rand -hex 64
JWT_SECRET=change-me-generate-with-openssl-rand-hex-64

# Nom de domaine utilisé par Caddy pour le certificat HTTPS (staging.<DOMAIN>
# pour l'instant, <DOMAIN> réservé pour la prod plus tard).
DOMAIN=example.com
