PORT=3000
NODE_ENV=development
PUBLIC_ORIGIN=http://localhost:3000

# Postgres connection string, e.g.: postgres://user:password@localhost:5432/salon
DATABASE_URL=postgres://user:password@localhost:5432/salon

# Generate a strong random secret, e.g.: openssl rand -hex 64
JWT_SECRET=replace_this_with_a_long_random_secret

# Controls the `Secure` flag on session/CSRF cookies. Leave unset to default
# to NODE_ENV (true in production). Set explicitly to false if you are
# running in production mode (e.g. `docker compose` with NODE_ENV=production)
# but accessing the site over plain http:// (no TLS in front of it yet) —
# otherwise the browser silently drops the cookies and login won't work.
# COOKIE_SECURE=false

# SMTP is entirely optional. Leave SMTP_HOST unset to run without email —
# booking confirmations are just logged to the console instead of sent, so
# nothing breaks. Fill these in once you have a real mailbox/provider (see
# README "Emails de confirmation" for examples: Gmail, Mailtrap, SendGrid…).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Carla Création" <no-reply@carlacreation.example>
