{
  "name": "carla-creation-api",
  "version": "2.0.0",
  "description": "NestJS API + static host for the Carla Création website (bookings, gallery, admin)",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "npm run migration:run && npm run seed:data && npm run seed && ts-node-dev --respawn --transpile-only src/main.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "typeorm": "TS_NODE_TRANSPILE_ONLY=true typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "seed:data": "TS_NODE_TRANSPILE_ONLY=true ts-node scripts/seed.ts",
    "seed": "TS_NODE_TRANSPILE_ONLY=true ts-node scripts/seedAdmin.ts",
    "backup": "TS_NODE_TRANSPILE_ONLY=true ts-node scripts/backup.ts",
    "smoketest": "TS_NODE_TRANSPILE_ONLY=true ts-node scripts/smoketest.ts"
  },
  "jest": {
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": ["<rootDir>/../test/env-setup.js"]
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "multer": "^2.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "typeorm": "^1.1.0",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0"
  }
}
