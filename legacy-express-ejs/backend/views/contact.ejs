<!DOCTYPE html>
<html lang="fr">
<head>
<%- include('partials/head', { title: 'Contact', description: 'Contactez ' + siteName + ' — coordonnées et formulaire de contact.' }) %>
</head>
<body>
<%- include('partials/header') %>

  <main id="main">
    <section class="section page-hero">
      <div class="container">
        <p class="eyebrow center">Contact</p>
        <h1 class="center">Venez nous rencontrer</h1>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container contact-grid">
        <div class="contact-info">
          <ul class="contact-list">
            <li><strong>Adresse</strong><span><%= siteAddress %></span></li>
            <li><strong>Téléphone</strong><span><a href="tel:<%= sitePhoneHref %>"><%= sitePhone %></a></span></li>
            <li><strong>Email</strong><span><a href="mailto:<%= siteEmail %>"><%= siteEmail %></a></span></li>
          </ul>
          <div class="map-placeholder" aria-hidden="true">
            <span>Carte / itinéraire à intégrer</span>
          </div>
        </div>

        <form id="contact-form" class="card contact-form" novalidate>
          <h3>Une question ?</h3>
          <div class="form-row">
            <label for="contactName">Nom</label>
            <input type="text" id="contactName" name="name" required minlength="2" maxlength="100" />
          </div>
          <div class="form-row">
            <label for="contactEmail">Email</label>
            <input type="email" id="contactEmail" name="email" required />
          </div>
          <div class="form-row">
            <label for="contactMessage">Message</label>
            <textarea id="contactMessage" name="message" rows="4" required minlength="5" maxlength="2000"></textarea>
          </div>
          <div class="honeypot" aria-hidden="true">
            <label for="contactWebsite">Ne pas remplir ce champ</label>
            <input type="text" id="contactWebsite" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <div id="contact-feedback" class="form-feedback" role="status" aria-live="polite"></div>
          <button type="submit" class="btn btn-primary btn-block">Envoyer le message</button>
        </form>
      </div>
    </section>
  </main>

<%- include('partials/footer') %>
<script type="module" src="/js/pages/contact.js"></script>
</body>
</html>
