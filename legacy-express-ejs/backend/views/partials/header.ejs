  <a class="skip-link" href="#main">Aller au contenu principal</a>

  <header class="site-header" id="top">
    <div class="container header-inner">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">✂</span>
        <span class="brand-name"><%= siteName %></span>
      </a>

      <nav class="main-nav" id="main-nav" aria-label="Navigation principale">
        <ul>
          <% navLinks.forEach(function (link) { %>
            <li><a href="<%= link.href %>" <%- link.key === activeKey ? 'aria-current="page"' : '' %>><%= link.label %></a></li>
          <% }); %>
        </ul>
      </nav>

      <a href="/booking" class="btn btn-primary nav-cta">Prendre rendez-vous</a>

      <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Ouvrir le menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>
